# Dev-mode container for the Vite frontend — used by ../docker-compose.yml so
# the whole viewer (backend + frontend) can run with a single `docker compose up`.
#
# Mirrors `npm install && npm run dev`; node_modules is kept in an anonymous
# volume (see compose file) so host/container installs don't clash.
FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install

EXPOSE 5173

CMD ["npm", "run", "dev"]
