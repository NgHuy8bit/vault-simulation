# Copy this file to `.env` (in the simulation-viewer/ directory, next to
# docker-compose.yml) and fill in your values. `.env` is gitignored — never
# commit real tokens.
#
# Why needed: `uv sync` inside the runner container must clone the private
# repo github.com/GalaxyFinX/smart-contracts (the `contracts-api` dependency).
# VS Code's devcontainer gets this for free via its credential-helper proxy;
# a standalone container needs an explicit token.
#
# How to create a token:
#   GitHub → Settings → Developer settings → Personal access tokens →
#   Fine-grained tokens → grant read-only "Contents" access to
#   GalaxyFinX/smart-contracts (or the classic "repo" scope for a classic PAT).

GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USER=your-github-username

# Optional — used for git commits made inside the container (rarely needed).
GIT_USER_EMAIL=you@example.com
GIT_USER_NAME=Your Name
